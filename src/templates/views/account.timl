// Page header
div.row > div.col-12.pt-4.pb-3
  div.row
    div.col-lg-6
      h2.mb-0: "Settings"
    div.col-lg-6.text-lg-end.align-self-center
      a.btn.btn-primary.btn-sm.rounded-3.btn-action-create-category: "Create Category"
  div.row.mt-2.mb-3
    div.col-lg-12 > div.px-3
      ul.nav.nav-underline
        li.nav-item
          a.nav-link.active href=dashboard("settings"): "General"
        li.nav-item
          a.nav-link href=dashboard("settings/users"): "Users"